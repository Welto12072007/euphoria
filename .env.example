# Frontend Vite + React
# Copie para .env.local e preencha com seus valores reais

# ── Clerk ──────────────────────────────────────────────────────────────────────
# Publishable key do Clerk (começa com pk_test_ ou pk_live_)
# Obtenha em: Clerk Dashboard > API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ───────────────────────────────────────────────────────────────────
# Obtenha em: Supabase > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Backend ────────────────────────────────────────────────────────────────────
# URL do backend Python (FastAPI)
# Em produção: https://your-backend.up.railway.app ou similar
VITE_API_URL=http://localhost:8000