# Backend Python — FastAPI
# Copie para .env e preencha com os seus valores reais

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtenha em: Supabase > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key — usada APENAS no backend para escrever no banco
# NUNCA exponha no frontend!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Clerk ─────────────────────────────────────────────────────────────────────
# JWKS URL do Clerk para verificar JWTs RS256
# Formato: https://<frontend-api>.clerk.accounts.dev/.well-known/jwks.json
# Ou: https://<your-domain>/.well-known/jwks.json (se domínio customizado)
# Obtenha no dashboard: Clerk > API Keys > Show JWT public key
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
